# ---- Database ----
DATABASE_URL=postgres://app:app@db:5432/english_learning
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=english_learning

# ---- Audio storage (shared volume) ----
AUDIO_DIR=/data/audio

# ---- Google Gemini (server-side only; never exposed to the frontend) ----
# Use a service account (preferred) or an API key.
# GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/service-account.json
GEMINI_API_KEY=
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
GEMINI_TRANSLATE_MODEL=gemini-2.5-flash
GEMINI_EXPLAIN_MODEL=gemini-2.5-flash
GEMINI_TTS_VOICE_EN=Kore
GEMINI_TTS_VOICE_ZH=Kore

# ---- Cloudflare Access (edge auth) ----
CF_ACCESS_TEAM_DOMAIN=
CF_ACCESS_AUD=

# ---- Local development ----
# When set to 1, the API bypasses Cloudflare Access verification and injects a
# dev identity. NEVER enable in production.
DEV_AUTH_BYPASS=1
DEV_USER_EMAIL=dev@example.com

# ---- Ports (host side) ----
API_PORT=8080
WEB_ADMIN_PORT=8081
WEB_LEARNER_PORT=8082
